{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AtlasDb": "Host=localhost;Port=5432;Database=atlas;Username=atlas;Password=change-me"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "AllowedHosts": "*",
  "AzureDevopsToken": "token",
  "Ai": {
    "MaxPromptChars": 4000,
    "MaxContextChars": 12000,
    "MaxConcurrentSessions": 4,
    "SystemPrompt": "You are Atlas AI assistant. Provide concise, practical guidance grounded only in supplied context. If context is missing, clearly say what is missing."
  },
  "OpenAI": {
    "Model": "gpt-4.1-mini",
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": ""
  }
}
